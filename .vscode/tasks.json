{
	"version": "2.0.0",
	"tasks": [
		{ // FOR WINDOWS
			"type": "cppbuild",
			"label": "C/C++: g++.exe build active file",
			"command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
			"args": [
				// 2. A FLAG DE DEPURAÇÃO:
				"-g", 
				"${file}",
				"-o",
				"${fileDirname}\\${fileBasenameNoExtension}.exe"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": ["$gcc"],
			"detail": "Task generated by Debugger.",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{ // FOR LINUX
			"type": "cppbuild",
			"label": "C/C++: g++ build active file",
			"command": "g++",
			"args": [
				// 2. A FLAG DE DEPURAÇÃO:
				"-g", 
				"${file}",
				"-o",
				"${fileDirname}/${fileBasenameNoExtension}"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": ["$gcc"],
			"detail": "Task generated by Debugger.",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
	]
}